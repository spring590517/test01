<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>104 AI+ 抽獎系統</title>
    <style>
        :root {
            --primary-orange: #f38230;
            --bg-color: #fffaf2;
        }
        body {
            font-family: "Microsoft JhengHei", sans-serif;
            background-color: var(--bg-color);
            display: flex;
            justify-content: center;
            padding: 20px;
        }
        .card {
            background: white;
            width: 100%;
            max-width: 400px;
            border-radius: 30px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            text-align: center;
        }
        .header h1 { color: #555; margin-bottom: 5px; font-size: 28px; }
        .header span { color: #a170e8; font-weight: bold; }
        .slogan { font-style: italic; color: #333; margin-bottom: 20px; font-weight: bold; }
        
        .input-group { text-align: left; margin-bottom: 15px; }
        label { display: block; font-size: 14px; font-weight: bold; color: #555; margin-bottom: 5px; }
        input, textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #eee;
            border-radius: 12px;
            background: #f9f9f9;
            box-sizing: border-box;
            font-size: 16px;
        }
        .btn-draw {
            background: var(--primary-orange);
            color: white;
            border: none;
            width: 100%;
            padding: 15px;
            border-radius: 30px;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            margin-top: 10px;
            box-shadow: 0 4px 15px rgba(243, 130, 48, 0.3);
        }
        .result-area {
            margin-top: 20px;
            padding: 15px;
            border-top: 2px dashed #eee;
            text-align: left;
            max-height: 200px;
            overflow-y: auto;
        }
        .prize-item { font-size: 14px; color: #666; margin-bottom: 5px; }
        .winner-tag { color: var(--primary-orange); font-weight: bold; }
    </style>
</head>
<body>

<div class="card">
    <div class="header">
        <h1>104 <span>AI+</span></h1>
        <div class="slogan">敢出發，就有路</div>
        <hr style="width: 40px; border: 2px solid var(--primary-orange); border-radius: 2px;">
    </div>

    <div class="input-group">
        <label>1. 設定參加抽獎的人數範圍 (1~N)</label>
        <input type="number" id="totalParticipants" value="100">
    </div>

    <div class="input-group">
        <label>2. 設定獎項與數量 (格式: 獎名,數量)</label>
        <textarea id="prizeSettings" rows="4" placeholder="例如：&#10;特獎,1&#10;頭獎,5&#10;參加獎,10">A獎,5&#10;B獎,10&#10;C獎,100</textarea>
    </div>

    <button class="btn-draw" onclick="startLottery()">Good Luck</button>

    <div class="result-area" id="resultArea">
        <p style="color: #ccc; text-align: center;">抽獎結果將顯示於此</p>
    </div>

    <div style="margin-top: 30px; color: #ccc; letter-spacing: 2px; font-weight: bold;">
        KEEP GOING ! <span style="color: var(--primary-orange)">104</span>
    </div>
</div>

<script>
    function startLottery() {
        const total = parseInt(document.getElementById('totalParticipants').value);
        const settings = document.getElementById('prizeSettings').value.trim().split('\n');
        const resultArea = document.getElementById('resultArea');
        
        // 生成抽獎池
        let pool = Array.from({length: total}, (_, i) => i + 1);
        let results = [];

        // 逐項抽取
        for (let line of settings) {
            let [name, count] = line.split(',');
            count = parseInt(count);
            
            if (!name || isNaN(count)) continue;

            let winners = [];
            for (let i = 0; i < count; i++) {
                if (pool.length === 0) break;
                const randomIndex = Math.floor(Math.random() * pool.length);
                winners.push(pool.splice(randomIndex, 1)[0]);
            }
            if (winners.length > 0) {
                results.push(`<strong>${name} (${winners.length}名):</strong> <span class="winner-tag">${winners.join(', ')}</span>`);
            }
        }

        // 顯示結果
        if (results.length === 0) {
            resultArea.innerHTML = '<p style="color:red;">請輸入正確的獎項設定</p>';
        } else {
            resultArea.innerHTML = '<h3>🎊 中獎名單</h3>' + results.map(r => `<div class="prize-item">${r}</div>`).join('');
        }
    }
</script>

</body>
</html>
